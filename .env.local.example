# Supabase Configuration
# Get these values from your Supabase project settings

# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT_ID].supabase.co:5432/postgres

# Supabase API URL
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co

# Supabase Anon Key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON_KEY]

# Supabase Service Role Key (secret, keep private)
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# Project ID
SUPABASE_PROJECT_ID=[PROJECT_ID]

# API Key (alternative to service role key)
SUPABASE_API_KEY=[API_KEY]
